# Environment Variables
# Copy this file to .env and fill in your values

# ───────────────────────────
# SERVER
# ───────────────────────────
PORT=5000
NODE_ENV=production

# ───────────────────────────
# POSTGRESQL (Prisma)
# ───────────────────────────
# Railway automatically injects DATABASE_URL when you attach a PostgreSQL service
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://user:password@host:5432/railway

# ───────────────────────────
# SECURITY
# ───────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this

# ───────────────────────────
# SUPER ADMIN CREDENTIALS
# ───────────────────────────
SUPER_ADMIN_USER=tashgheel
SUPER_ADMIN_PASS=BuFF@li2025#

# ───────────────────────────
# EMAIL (Optional — for registration notifications)
# ───────────────────────────
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-app-password

# ───────────────────────────
# INTEGRATIONS (Optional — set via Admin UI)
# ───────────────────────────
# These are managed per-tenant in the database, but you can set defaults here.
# Typically configured through Admin > E-Commerce Settings in the UI.
